# -----------------------------------------------------------------------
# media-delivery environment variables
# Copy this file to .env and fill in the values.
# -----------------------------------------------------------------------

# --- Server ---
HOST=0.0.0.0
PORT=3000
ADMIN_PORT=3001
CDN_NAME=media-proxy.example.com   # Required: set to your proxy's hostname

# --- Cache (L1 disk) ---
CACHE_DIR=/cache
CACHE_MAX_BYTES=2GiB
CACHE_TARGET_BYTES=1GiB

# --- L2 Object Storage (optional) ---
S3_ENABLED=false
#S3_ENDPOINT=https://....r2.cloudflarestorage.com
#S3_BUCKET=media-cache
#S3_ACCESS_KEY=
#S3_SECRET_KEY=
#S3_LIFECYCLE_DAYS=42
#S3_RENEW_AFTER_DAYS=28

# --- State Backend ---
STORE_BACKEND=memory       # memory | redis
#REDIS_ADDR=localhost:6379
#REDIS_PASSWORD=
#REDIS_DB=0

# --- Fetch ---
FETCH_TIMEOUT=30s
FETCH_MAX_REDIRECTS=3
MAX_FILE_SIZE=250MiB

# --- Image Conversion ---
#CONVERT_CONCURRENCY=       # default: NumCPU
CONVERT_WEBP_QUALITY=80
CONVERT_PNG_COMPRESSION=6
CONVERT_ANIM_QUALITY=75

# --- Fallback Images (file path or base64; leave empty for built-in defaults) ---
#FALLBACK_AVATAR=
#FALLBACK_EMOJI=
#FALLBACK_BADGE=
#FALLBACK_DEFAULT=

# --- Security: SSRF / Blacklist ---
#ORIGIN_ALLOWED_PRIVATE_NETWORKS=   # CIDRs allowed as origin (comma-separated)
#ORIGIN_BLACKLIST_DOMAINS=          # e.g. malicious.example.com,spam.example.org
#ORIGIN_BLACKLIST_IPS=              # e.g. 1.2.3.4/32,5.6.7.0/24
#ORIGIN_BLACKLIST_FILE=             # path to blacklist file (hot-reload)

# --- Circuit Breaker ---
CIRCUIT_BREAKER_ENABLED=true
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=5m

# --- Negative Cache TTL ---
NEGATIVE_CACHE_TTL_40X=24h
NEGATIVE_CACHE_TTL_5XX=5m

# --- Logging ---
LOG_LEVEL=INFO             # DEBUG | INFO | WARN | ERROR
